# ProfanityBench — open profanity dataset (GaaliGPT is the app UI name)
# Path to your JSONL dataset (default: ./data/gaalis.jsonl)
GAALI_DATA_PATH=./data/gaalis.jsonl

# Standalone hosting: leave USE_OLLAMA false (default). Search + cards work without any LLM.
USE_OLLAMA=false

# Only if USE_OLLAMA=true:
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT_MS=12000
